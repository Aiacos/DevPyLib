# ==============================================================================
# Maya Environment Variables - Cross-Platform Configuration
# ==============================================================================
#
# INSTRUCTIONS: Uncomment and configure MAIN_PATH for your operating system
#
# NOTE: Maya supports forward slashes (/) on all platforms, but variable
#       syntax differs between Windows (%VAR%) and Unix ($VAR)
#
# ==============================================================================

# ----------------------
# Windows Configuration
# ----------------------
# Uncomment the following lines if on Windows:
MAIN_PATH=C:/Users/%USERNAME%/Documents/workspace
DEVPYLIB_PATH=%MAIN_PATH%/DevPyLib
MAYA_APP_DIR=%DEVPYLIB_PATH%
PYTHONPATH=%DEVPYLIB_PATH%
MAYA_MODULE_PATH=%MAIN_PATH%/DevPyLib/maya/Plug-ins/mocapx_2.2.1_Maya2024_win
MAYA_PLUG_IN_PATH=%MAIN_PATH%/DevPyLib/maya/Plug-ins/CharacoalEditor

# ----------------------
# Linux Configuration
# ----------------------
# Uncomment the following lines if on Linux (and comment out Windows section):
# MAIN_PATH=$HOME/workspace
# DEVPYLIB_PATH=$MAIN_PATH/DevPyLib
# MAYA_APP_DIR=$DEVPYLIB_PATH
# PYTHONPATH=$DEVPYLIB_PATH
# MAYA_MODULE_PATH=$MAIN_PATH/DevPyLib/maya/Plug-ins/mocapx_2.2.1_Maya2024_win
# MAYA_PLUG_IN_PATH=$MAIN_PATH/DevPyLib/maya/Plug-ins/CharacoalEditor

# ----------------------
# macOS Configuration
# ----------------------
# Uncomment the following lines if on macOS (and comment out Windows section):
# MAIN_PATH=$HOME/workspace
# DEVPYLIB_PATH=$MAIN_PATH/DevPyLib
# MAYA_APP_DIR=$DEVPYLIB_PATH
# PYTHONPATH=$DEVPYLIB_PATH
# MAYA_MODULE_PATH=$MAIN_PATH/DevPyLib/maya/Plug-ins/mocapx_2.2.1_Maya2024_win
# MAYA_PLUG_IN_PATH=$MAIN_PATH/DevPyLib/maya/Plug-ins/CharacoalEditor
