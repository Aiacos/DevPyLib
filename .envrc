# ============================================================================
# DevPyLib Environment Configuration (direnv)
#
# This file is automatically loaded by direnv when you cd into this directory.
#
# Setup:
#   1. Install direnv: https://direnv.net/
#   2. Add to ~/.bashrc or ~/.zshrc:
#      eval "$(direnv hook bash)"  # or zsh
#   3. Allow this directory:
#      direnv allow
#
# Benefits:
#   - Automatic environment activation
#   - No manual export needed
#   - Works with all tools (not just Neovim)
#   - Shell integration
# ============================================================================

# Detect mayapy path
detect_mayapy() {
    # Try detection script
    if [ -f "scripts/detect_mayapy.py" ]; then
        local mayapy=$(python3 scripts/detect_mayapy.py 2>/dev/null)
        if [ -n "$mayapy" ] && [ -x "$mayapy" ]; then
            echo "$mayapy"
            return 0
        fi
    fi

    # Fallback to common paths
    local candidates=(
        "/usr/autodesk/maya2024/bin/mayapy"
        "/usr/autodesk/maya2023/bin/mayapy"
        "/usr/autodesk/maya2022/bin/mayapy"
    )

    for mayapy in "${candidates[@]}"; do
        if [ -x "$mayapy" ]; then
            echo "$mayapy"
            return 0
        fi
    done

    return 1
}

# Set mayapy as Python interpreter
MAYAPY=$(detect_mayapy)
if [ -n "$MAYAPY" ]; then
    export MAYAPY
    export PYTHONPATH="$($MAYAPY -c 'import sys; print(":".join(sys.path))' 2>/dev/null)"

    # For tools that respect these
    export PYTHON="$MAYAPY"
    export PYTHON_PATH="$MAYAPY"

    # Log activation
    echo "✓ DevPyLib environment activated"
    echo "  Python: $MAYAPY"
    echo "  Use 'pytest' or './scripts/test_with_maya.sh' to run tests"
else
    echo "⚠ Warning: mayapy not found, using system Python"
fi

# Add scripts to PATH
PATH_add scripts

# Set project root
export DEVPYLIB_ROOT="$(pwd)"

# Optional: Activate Python virtual environment if exists
# if [ -d ".venv" ]; then
#     source .venv/bin/activate
# fi
