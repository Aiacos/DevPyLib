#
# NOTE: The use of packages is highly recommended instead of houdini.env 
# See details about packages here: https://www.sidefx.com/docs/houdini21.0/ref/plugins.html
#
# Houdini Environment Settings
#
# The contents of this file are read into the environment
# at startup.  They will override any existing entries in
# the environment.
#
# The syntax is one entry per line as follows:
#    VAR = VALUE
#
# Values may be quoted
#    VAR = "VALUE"
#
# Values may be empty
#    VAR = 
#

# Example:
#
# HOUDINI_NO_SPLASH = 1


# ==============================================================================
# Houdini Environment Variables - Cross-Platform Configuration
# ==============================================================================
#
# INSTRUCTIONS: Uncomment and configure MAIN_PATH for your operating system
#
# NOTE: Houdini supports forward slashes (/) on all platforms, but variable
#       syntax differs between Windows (%VAR%) and Unix ($VAR)
#
# ==============================================================================

# ----------------------
# Windows Configuration
# ----------------------
# Uncomment the following lines if on Windows:
MAIN_PATH = C:/Users/%USERNAME%/Documents
HOUDINI_USER_DIR = %MAIN_PATH%/houdini21.0
HOUDINI_OTLSCAN_PATH = %MAIN_PATH%/workspace/DevPyLib/houdiniLib/HDAs;&


# ----------------------
# Linux Configuration
# ----------------------
# Uncomment the following lines if on Linux (and comment out Windows section):
# MAIN_PATH = $HOME
# HOUDINI_USER_DIR = $MAIN_PATH/houdini21.0
# HOUDINI_OTLSCAN_PATH = %MAIN_PATH%/workspace/DevPyLib/houdiniLib/HDAs;&


# ----------------------
# macOS Configuration
# ----------------------
# Uncomment the following lines if on macOS (and comment out Windows section):
# MAIN_PATH = $HOME
# HOUDINI_USER_DIR = $MAIN_PATH/Library/Preferences/houdini21.0
# HOUDINI_OTLSCAN_PATH = %MAIN_PATH%/workspace/DevPyLib/houdiniLib/HDAs;&


